# ACE runtime mode: demo or live
ACE_MODE=demo

# Arc testnet RPC
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# Circle x402 Gateway
CIRCLE_FACILITATOR_URL=https://gateway-api-testnet.circle.com
X402_SETTLEMENT_MODE=demo
GATEWAY_WALLET_CONTRACT=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
USDC_CONTRACT=0x000000000000000000000000000000000000ACE2
SELLER_ADDRESS=0x000000000000000000000000000000000000ACE3

# SQLite database path
DATABASE_URL=sqlite:///./data/ace.db

# DeepSeek / OpenAI-compatible LLM key
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash

# Wallet private keys (live mode only — never commit real keys)
PRODUCER_PRIVATE_KEY=
CONSUMER_PRIVATE_KEY=
AUDITOR_PRIVATE_KEY=

# Economic defaults
ESTIMATED_DIRECT_INPUT_KT=120
ESTIMATED_DIRECT_OUTPUT_KT=30
PRICE_INPUT_PER_MT=0.14
PRICE_OUTPUT_PER_MT=0.28
